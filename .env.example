PORT=4173

# Supabase project settings
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=replace-with-your-publishable-or-anon-key
# SUPABASE_ANON_KEY=replace-with-your-anon-key-if-not-using-publishable-key

# Server-side only. Never expose this in frontend JavaScript.
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key-server-only

# Admin dashboard access
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_SECRET=replace-with-a-long-random-secret

NODE_ENV=production
